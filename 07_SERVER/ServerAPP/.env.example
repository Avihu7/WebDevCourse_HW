# Copy this file to .env and fill in your values
# cp .env.example .env

# Server port (Render sets this automatically; leave as-is for local dev)
PORT=3000

# A long random string for signing session cookies
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change_this_to_a_long_random_string

# YouTube Data API v3 key
# Get one at https://console.cloud.google.com/ → Enable "YouTube Data API v3" → Credentials → API key
YOUTUBE_API_KEY=your_youtube_api_key_here

# Optional: custom path for the SQLite database file
# DB_PATH=/absolute/path/to/db.sqlite
