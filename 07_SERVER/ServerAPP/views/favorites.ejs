<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My YouTube Favorites</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
</head>
<body class="bg-light">

    <!-- Navbar -->
    <nav class="navbar navbar-dark bg-dark mb-4">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">MyApp</a>
            <div class="d-flex align-items-center gap-3">
                <span class="text-light small">Signed in as <strong><%= user.email %></strong></span>
                <form method="POST" action="/logout" class="mb-0">
                    <button class="btn btn-outline-light btn-sm">Logout</button>
                </form>
            </div>
        </div>
    </nav>

    <div class="container pb-5">

        <!-- ====== SECTION 1: Search (top) ====== -->
        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <h4 class="card-title mb-3">Search YouTube Videos</h4>

                <form method="POST" action="/favorites/search">
                    <div class="input-group">
                        <input
                            name="query"
                            type="text"
                            class="form-control"
                            placeholder="Search for a video..."
                            value="<%= query %>"
                            required
                        />
                        <button type="submit" class="btn btn-primary">Search</button>
                    </div>
                </form>

                <% if (error) { %>
                    <div class="alert alert-danger mt-3 mb-0"><%= error %></div>
                <% } %>

                <!-- Search Results -->
                <% if (searchResults.length > 0) { %>
                    <h5 class="mt-4 mb-3">Results for "<%= query %>"</h5>
                    <div class="row g-3">
                        <% searchResults.forEach(function(video) { %>
                        <div class="col-sm-6 col-lg-3">
                            <div class="card h-100">
                                <img
                                    src="<%= video.thumbnail %>"
                                    class="card-img-top"
                                    alt="<%= video.title %>"
                                    style="object-fit:cover; height:140px;"
                                >
                                <div class="card-body d-flex flex-column p-2">
                                    <p class="card-text small fw-semibold mb-1" style="line-height:1.3;">
                                        <%= video.title %>
                                    </p>
                                    <p class="card-text text-muted small mb-2"><%= video.channelTitle %></p>
                                    <div class="mt-auto d-flex gap-1 flex-wrap">
                                        <a
                                            href="https://www.youtube.com/watch?v=<%= video.videoId %>"
                                            target="_blank"
                                            class="btn btn-outline-danger btn-sm"
                                        >Watch</a>
                                        <form method="POST" action="/favorites/add" class="d-inline">
                                            <input type="hidden" name="videoId" value="<%= video.videoId %>">
                                            <input type="hidden" name="title" value="<%= video.title %>">
                                            <input type="hidden" name="channelTitle" value="<%= video.channelTitle %>">
                                            <input type="hidden" name="thumbnail" value="<%= video.thumbnail %>">
                                            <button type="submit" class="btn btn-success btn-sm">+ Save</button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <% }); %>
                    </div>
                <% } else if (query) { %>
                    <p class="text-muted mt-3 mb-0">No results found for "<%= query %>".</p>
                <% } %>
            </div>
        </div>

        <!-- ====== SECTION 2: Saved Favorites (bottom) ====== -->
        <div class="card shadow-sm">
            <div class="card-body">
                <h4 class="card-title mb-3">
                    My Saved Favorites
                    <span class="badge bg-secondary ms-1"><%= favorites.length %></span>
                </h4>

                <% if (favorites.length === 0) { %>
                    <p class="text-muted mb-0">
                        You have no saved favorites yet. Search for a video above and click <strong>+ Save</strong>.
                    </p>
                <% } else { %>
                    <div class="row g-3">
                        <% favorites.forEach(function(fav) { %>
                        <div class="col-sm-6 col-lg-3">
                            <div class="card h-100">
                                <img
                                    src="<%= fav.thumbnail %>"
                                    class="card-img-top"
                                    alt="<%= fav.title %>"
                                    style="object-fit:cover; height:140px;"
                                >
                                <div class="card-body d-flex flex-column p-2">
                                    <p class="card-text small fw-semibold mb-1" style="line-height:1.3;">
                                        <%= fav.title %>
                                    </p>
                                    <p class="card-text text-muted small mb-2"><%= fav.channelTitle %></p>
                                    <div class="mt-auto d-flex gap-1 flex-wrap">
                                        <a
                                            href="https://www.youtube.com/watch?v=<%= fav.videoId %>"
                                            target="_blank"
                                            class="btn btn-outline-danger btn-sm"
                                        >Watch</a>
                                        <form
                                            method="POST"
                                            action="/favorites/delete/<%= fav.id %>"
                                            class="d-inline"
                                            onsubmit="return confirm('Remove this video from favorites?')"
                                        >
                                            <button type="submit" class="btn btn-outline-secondary btn-sm">Remove</button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <% }); %>
                    </div>
                <% } %>
            </div>
        </div>

        <div class="mt-3 text-center">
            <a href="/" class="text-muted small">← Back to Home</a>
        </div>
    </div>

</body>
</html>
